# ── Runtime mode ──────────────────────────────────────────────────────
# Set DEMO_MODE=true to bypass all external LLM/STT/TTS calls and use
# pre-canned responses. Useful for running the app without any API keys.
DEMO_MODE=false

# ── LLM providers (at least one required unless DEMO_MODE=true) ──────
# Groq (free, fast) — https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key

# Google Gemini (free tier) — https://aistudio.google.com/apikey
# Also used for PDF resume parsing via Gemini multimodal.
GEMINI_API_KEY=your_gemini_api_key

# OpenRouter (free community pool) — https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=your_openrouter_api_key

# OpenAI (paid) — https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key

# ── Text-to-speech (optional — avatar voice) ─────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=245byKg3uV4vDjJ8fSV8

# ── Supabase (optional — interview transcript persistence) ───────────
SUPABASE_URL=your_supabase_project_url
SUPABASE_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key
